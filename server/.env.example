# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/trading_platform?schema=public"

# Supabase Client (anon key + project URL — get from Supabase Dashboard → Settings → API)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key-here"

# JWT
JWT_ACCESS_SECRET="your-access-secret-key-change-this"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-this"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Email (Nodemailer)
# Use a 16-character Google App Password (xxxx-xxxx-xxxx-xxxx) for EMAIL_PASS.
# Instructions to generate: Google Account -> Security -> 2-Step Verification -> App Passwords -> generate for "Mail".
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="xxxx-xxxx-xxxx-xxxx"
EMAIL_FROM="TradeSphere <noreply@tradesphere.com>"

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL="http://localhost:5173"
